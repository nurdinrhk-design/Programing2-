	<queryString>
		<![CDATA[SELECT n.id_nilai, n.nim, m.nama, n.semester, n.kelas, n.kode_mk, mk.nama_mk, n.tugas, n.uts, n.uas, n.nilai_akhir, n.huruf, n.status FROM nilai n JOIN mahasiswa m ON n.nim = m.nim JOIN mata_kuliah mk ON n.kode_mk = mk.kode_mk ORDER BY n.id_nilai ASC]]>
	</queryString>
